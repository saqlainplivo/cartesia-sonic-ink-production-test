# ─── Plivo ───────────────────────────────────────────────────────────────────
PLIVO_AUTH_ID=your_plivo_auth_id
PLIVO_AUTH_TOKEN=your_plivo_auth_token
PLIVO_FROM_NUMBER=+1XXXXXXXXXX      # Your Plivo DID (must be voice-capable)
PLIVO_TO_NUMBER=+1XXXXXXXXXX        # Phone to call during real-call tests

# ─── Cartesia ────────────────────────────────────────────────────────────────
CARTESIA_API_KEY=your_cartesia_api_key

# Model IDs — update to exact Cartesia release strings when Sonic-3.5 is GA
CARTESIA_MODEL_SONIC_35=sonic-2        # Sonic-3.5 / latest
CARTESIA_MODEL_SONIC_3=sonic           # Sonic-3 / stable
CARTESIA_MODEL_INK_2=ink-2             # Ink-2 STT model

# Voice ID used for TTS (find yours at app.cartesia.ai/voices)
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# ─── Server ──────────────────────────────────────────────────────────────────
WEBHOOK_BASE_URL=https://REPLACE-WITH-YOUR-NGROK-URL.ngrok-free.app
WEBHOOK_PORT=5000

# ─── STT for WER scoring ─────────────────────────────────────────────────────
# whisper_local uses openai-whisper (CPU, no extra key needed)
# Options: whisper_local | deepgram | assemblyai
STT_PROVIDER=whisper_local
WHISPER_MODEL=base.en               # tiny.en | base.en | small.en | medium.en
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=

# ─── Eval guardrails ─────────────────────────────────────────────────────────
MAX_REAL_CALLS_PER_RUN=10           # Hard cap — each call costs real money
CALL_TIMEOUT_SECONDS=90
REPEATS_PER_CATEGORY=5              # Calls per script × model for latency stats
